# LLM API Keys (Groq is primary, Gemini is fallback)
# Get Groq key from: https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# Get Gemini key from: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=your_google_api_key_here

# Vector Database (Qdrant)
# Use cloud URL or localhost for self-hosted
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=your_qdrant_api_key_here

# Redis (for chat memory)
# Use cloud URL or localhost for self-hosted
REDIS_URL=redis://localhost:6379/0

# SQLite Database (metadata storage)
DATABASE_URL=sqlite+aiosqlite:///./app.db
